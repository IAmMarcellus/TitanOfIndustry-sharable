{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow"
  },
  "compaction": {
    "auto": true,
    "reserved": 32768
  },
  "provider": {
    "local-vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local vLLM (Qwen codex AWQ)",
      "options": {
        "baseURL": "{env:OPENAI_BASE_URL}",
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "qwen-codex": {
          "name": "Qwen 3.6 27B (codex, AWQ)",
          "limit": { "context": 65536, "output": 8192 }
        }
      }
    }
  }
}
